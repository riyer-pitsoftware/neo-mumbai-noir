# Neo-Mumbai Noir Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Stock Image Search ────────────────────────────────────────────────────────
# Pexels: free API key at https://www.pexels.com/api/
PEXELS_API_KEY=
# Unsplash: free API key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Host Services (set in docker-compose.yml, override here if needed) ────────
# These are normally configured in docker-compose.yml as environment vars
# pointing to host.docker.internal. Only set here to override.
# OLLAMA_HOST=host.docker.internal:11434
# COMFYUI_HOST=host.docker.internal:8188
# FACEFUSION_HOST=host.docker.internal:7870
